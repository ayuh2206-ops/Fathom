# Firebase Admin (server-side)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Storage
FIREBASE_STORAGE_BUCKET=

# Firebase Client (public - for realtime fleet sync)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# NextAuth
NEXTAUTH_URL=https://your-domain.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Admin Panel
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Generate with: openssl rand -base64 32
ADMIN_PANEL_SECRET=

# ─── Anthropic AI (invoice analysis, fraud detection, dispute letters) ───────
# Get key: console.anthropic.com → API Keys → Create key
# Use claude-haiku-4-5 model only — cheapest, fast enough
ANTHROPIC_API_KEY=

# Legacy variable retained for compatibility while OpenAI code is removed
OPENAI_API_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid (transactional email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@yourfathom.com
SENDGRID_FROM_NAME=FATHOM Maritime

# Mapbox (fleet map)
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── AISStream (real-time vessel position tracking via WebSocket) ─────────────
# Get free key: aisstream.io → Sign up → Dashboard → API key shown immediately
AISSTREAM_API_KEY=

# ─── VesselAPI (seed last known vessel position on add) ───────────────────────
# Get free developer key: vesselapi.com
VESSEL_API_KEY=

# ─── Datalastic (port call history — arrival/departure timestamps) ────────────
# Get key: datalastic.com → Sign up → Dashboard
# Optional for MVP — AIS real-time works without this
DATALASTIC_API_KEY=

# Legacy variable retained from previous AIS provider experiments
MARINE_TRAFFIC_API_KEY=

# Current billing integration in this repo (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_SCOUT=
RAZORPAY_PLAN_NAVIGATOR=
RAZORPAY_PLAN_ADMIRAL=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
